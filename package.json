{
  "name": "gaokao-wuli-audit",
  "private": true,
  "scripts": {
    "check": "node scripts/check.js --strict && node scripts/check-editorial-coverage.js && node scripts/check-math-content.js && node scripts/check-solutions.js && node scripts/check-static-fallback.js && node eval/static-eval.mjs --gate",
    "audit:static": "node scripts/check.js --audit-write && node scripts/anim-audit.js",
    "audit:interaction": "AUDIT_MODULE=all AUDIT_REPORT=interaction-audit.json playwright test tests/interaction-audit.spec.js --workers=1",
    "audit:interaction:module": "playwright test tests/interaction-audit.spec.js --workers=1",
    "audit:pedagogy:b1": "playwright test tests/b1-priority-pedagogy.spec.js --workers=1",
    "audit:physics:b1": "playwright test tests/b1-remaining-physics.spec.js tests/b1-dynamic-equilibrium.spec.js --workers=1",
    "audit:physics:b2": "playwright test tests/b2-physics-pedagogy.spec.js --workers=1",
    "audit:physics:b3": "playwright test tests/b3-physics-pedagogy.spec.js --workers=1",
    "audit:pedagogy:b2": "playwright test tests/b2-guided-pedagogy.spec.js --workers=1",
    "audit:pedagogy:b3": "playwright test tests/b3-guided-pedagogy.spec.js --workers=1",
    "audit:physics:x1": "playwright test tests/x1-physics-pedagogy.spec.js --workers=1",
    "audit:pedagogy:x1": "playwright test tests/x1-guided-pedagogy.spec.js --workers=1",
    "audit:physics:x2": "playwright test tests/x2-physics-pedagogy.spec.js --workers=1",
    "audit:pedagogy:x2": "playwright test tests/x2-guided-pedagogy.spec.js --workers=1",
    "audit:physics:x3": "playwright test tests/x3-physics-pedagogy.spec.js --workers=1",
    "audit:pedagogy:x3": "playwright test tests/x3-guided-pedagogy.spec.js --workers=1",
    "audit:physics:g7": "playwright test tests/g7-physics-pedagogy.spec.js --workers=1",
    "audit:pedagogy:g7": "playwright test tests/g7-guided-pedagogy.spec.js --workers=1",
    "eval:static": "node eval/static-eval.mjs",
    "eval:compile": "node eval/compile-results.mjs && node eval/score-pages.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
